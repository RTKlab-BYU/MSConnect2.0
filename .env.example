DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:8080,http://127.0.0.1:8080
DJANGO_TIME_ZONE=America/Denver

SQLITE_PATH=/app/data/db.sqlite3
SQLITE_TIMEOUT_SECONDS=20
MEDIA_ROOT=/app/media
STATIC_ROOT=/app/staticfiles
INCOMING_RAW_ROOT=/data/incoming
RAW_FILE_STORAGE_ROOT=/data/raw
RESULTS_ROOT=/data/results

INCOMING_RAW_HOST_PATH=./incoming
RAW_STORAGE_HOST_PATH=./raw-storage
RESULTS_HOST_PATH=./results
MSCONNECT_DATA_HOST_PATH=./data
MSCONNECT_MEDIA_HOST_PATH=./media
MSCONNECT_STATIC_HOST_PATH=./staticfiles
MSCONNECT_WEB_PORT=8000
MSCONNECT_NGINX_PORT=8080

MSCONNECT_WATCHER_TOKEN=watcher-token
MSCONNECT_PROCESSOR_TOKEN=processor-token
MSCONNECT_API_BASE_URL=http://web:8000/api
WATCHER_AGENT_NAME=watcher-1
PROCESSOR_AGENT_NAME=processor-1
MSCONNECT_AGENT_HEARTBEAT_SECONDS=30
WATCHER_INTERVAL_SECONDS=60
PROCESSOR_POLL_INTERVAL_SECONDS=15
MSCONNECT_IMAGE=msconnect:local
MSCONNECT_AUTO_QUEUE_SPECTRA_CONVERSION=0
MSCONNECT_MSCONVERT_EXECUTABLE=msconvert
MSCONNECT_MSCONVERT_OUTPUT_FORMAT=mzML
MSCONNECT_PWIZ_VERSION=site-configured
MSCONNECT_DIANN_IMAGE=msconnect-processor-diann:local
MSCONNECT_FRAGPIPE_IMAGE=msconnect-processor-fragpipe:local
MSCONNECT_PWIZ_IMAGE=msconnect-processor-pwiz:local
DIANN_AGENT_NAME=diann-1
FRAGPIPE_AGENT_NAME=fragpipe-1
PWIZ_AGENT_NAME=pwiz-1
DIANN_LINUX_URL=
FRAGPIPE_URL=
