DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_TIME_ZONE=America/Denver

SQLITE_PATH=/app/data/db.sqlite3
MEDIA_ROOT=/app/media
STATIC_ROOT=/app/staticfiles
INCOMING_RAW_ROOT=/data/incoming
RAW_FILE_STORAGE_ROOT=/data/raw

INCOMING_RAW_HOST_PATH=./incoming
RAW_STORAGE_HOST_PATH=./raw-storage
MSCONNECT_DATA_HOST_PATH=./data
MSCONNECT_MEDIA_HOST_PATH=./media
MSCONNECT_STATIC_HOST_PATH=./staticfiles

